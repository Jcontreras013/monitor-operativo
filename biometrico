import pandas as pd
import streamlit as st

def procesar_biometrico(df):
    """
    Depura el reporte según el área y las reglas de marcado.
    """
    st.subheader("📊 Reporte Biométrico Depurado")
    
    # Asegurar formato de hora HH:mm:ss
    if 'time' in df.columns:
        df['time'] = pd.to_datetime(df['time']).dt.strftime('%H:%M:%S')

    # Diccionario de reglas por área
    reglas = {
        "AREA TECNICA": ["Entrada", "Salida"],
        "SAC": ["Entrada", "Salida Almuerzo", "Entrada Almuerzo", "Break", "Salida"],
        "ADMINISTRACION": ["Entrada", "Salida Almuerzo", "Entrada Almuerzo", "Salida"]
    }

    # Asumiendo que existe una columna 'area' o 'departamento'
    areas = df['area'].unique() if 'area' in df.columns else []

    for area in areas:
        if area in reglas:
            st.write(f"### {area}")
            eventos_permitidos = reglas[area]
            # Filtrar por área y por los eventos que le corresponden
            df_filtrado = df[(df['area'] == area) & (df['evento'].isin(eventos_permitidos))]
            st.dataframe(df_filtrado[['name', 'time', 'evento']])

def vista_biometrico():
    st.title("📌 Centro de Reportes - Biométrico")
    archivo = st.file_uploader("Cargar reporte biométrico (Excel/CSV)", type=['xlsx', 'csv'])
    
    if archivo:
        df = pd.read_excel(archivo) if archivo.name.endswith('xlsx') else pd.read_csv(archivo)
        procesar_biometrico(df)
